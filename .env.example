# =============================================================
# ClinicalTrialEnv — Environment Variables (Example)
# Copy this file to '.env' and replace placeholder values
# =============================================================

# --- OLLAMA LOCAL SETUP (Default) ---
# When running Ollama locally, you do not need actual API keys.
HF_TOKEN=ollama
API_BASE_URL=http://localhost:11434/v1
MODEL_NAME=llama3.2   # or llama3.1:8b for better JSON structure parsing

# --- HUGGINGFACE INFERENCE ROUTER SETUP ---
# To use HuggingFace serverless inference, uncomment lines below:
# HF_TOKEN=hf_your_actual_token_here
# API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct

# --- GOOGLE GEMINI (For synthetic data generation script) ---
# Needed if you edit scripts/generate_all.py to use Google's Gemini SDK instead of local Ollama
# Get your free key at https://aistudio.google.com

GEMINI_API_KEY=your_gemini_api_key_here